# Python interpreter used to run the core scripts.
# Default: whatever "python" resolves to on your PATH.
# PROCMUSIC_PYTHON=C:\Users\Work\python312\python.exe

# Directory where transcribed MIDI files are written.
# Each piece lands at $MIDI_OUTPUT_DIR/<piece_id>/{melody,bass,...}.mid
# Default: ../procmusic-dashboard/dashboard/showcase-midi
# MIDI_OUTPUT_DIR=C:\path\to\procmusic-dashboard\dashboard\showcase-midi
